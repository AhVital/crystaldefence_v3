<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="UL 752 Certified Armored Glass Products - 8 Levels of Protection RL1-RL8">
    <title>{% block title %}Products | Crystal Defence{% endblock %}</title>
    
    <!-- Подключение стилей -->
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/responsive.css">
</head>

<body class="products-page">
    <!-- Header Navigation -->
    <header class="header">
        <nav class="header__nav">
            <a href="#home" data-section="home">Home</a>
            <a href="#about" data-section="about">About Us</a>
            <a href="#contact" data-section="contact">Contact</a>
        </nav>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero__background">
            <img src="/img/page1/background2.png" alt="" class="hero-bg" style="opacity: 0.6;">
        </div>
        <div class="hero__content">
            <h1 data-i18n="products_title">Our Products - UL 752 Certified</h1>
            <p class="hero__subtitle" data-i18n="products_subtitle">8 Levels of Protection. Custom Thickness Options.</p>
        </div>
    </section>

    <!-- Product Grid with UL 752 Levels -->
    <section class="product-grid">
        <!-- Level 1 -->
        <article class="card product-card" data-level="rl1">
            <h3 data-i18n="level_1_title">Level 1 (RL-1)</h3>
            <p class="thickness" data-i18n="level_1_thickness">4-6mm</p>
            <img src="/img/page2/1.png" alt="RL-1 Protection Level" style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px;">
            <p class="description" data-i18n="level_1_desc">Protection against knives and handgun bullets up to 9mm. Ideal for basic office protection.</p>
            <p class="applications" data-i18n="level_1_applications">Offices, Banks (basic protection)</p>
        </article>

        <!-- Level 2 -->
        <article class="card product-card" data-level="rl2">
            <h3 data-i18n="level_2_title">Level 2 (RL-2)</h3>
            <p class="thickness" data-i18n="level_2_thickness">7-8mm</p>
            <img src="/img/page2/2.png" alt="RL-2 Protection Level" style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px;">
            <p class="description" data-i18n="level_2_desc">Protection against pistol caliber up to .357 Magnum. Suitable for ATMs and bank terminals.</p>
            <p class="applications" data-i18n="level_2_applications">ATMs, Bank Terminals</p>
        </article>

        <!-- Level 3 -->
        <article class="card product-card" data-level="rl3">
            <h3 data-i18n="level_3_title">Level 3 (RL-3)</h3>
            <p class="thickness" data-i18n="level_3_thickness">10-12mm</p>
            <img src="/img/page2/3.png" alt="RL-3 Protection Level" style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px;">
            <p class="description" data-i18n="level_3_desc">Protection against semi-automatic pistols and rifle fragments. Suitable for kiosks.</p>
            <p class="applications" data-i18n="level_3_applications">Kiosks, Entry Points</p>
        </article>

        <!-- Level 4 -->
        <article class="card product-card" data-level="rl4">
            <h3 data-i18n="level_4_title">Level 4 (RL-4)</h3>
            <p class="thickness" data-i18n="level_4_thickness">12-15mm</p>
            <img src="/img/page2/4.png" alt="RL-4 Protection Level" style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px;">
            <p class="description" data-i18n="level_4_desc">Protection against small arms including rifle rounds up to 5.56mm. Suitable for VPK zones.</p>
            <p class="applications" data-i18n="level_4_applications">VPK Zones, KPPs</p>
        </article>

        <!-- Level 5 -->
        <article class="card product-card" data-level="rl5">
            <h3 data-i18n="level_5_title">Level 5 (RL-5)</h3>
            <p class="thickness" data-i18n="level_5_thickness">25-30mm</p>
            <img src="/img/page2/5.png" alt="RL-5 Protection Level" style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px;">
            <p class="description" data-i18n="level_5_desc">Protection against pistol cartridges and rifle bullets. Ideal for bunkers and VIP areas.</p>
            <p class="applications" data-i18n="level_5_applications">Bunkers, VIP Areas</p>
        </article>

        <!-- Level 6 -->
        <article class="card product-card" data-level="rl6">
            <h3 data-i18n="level_6_title">Level 6 (RL-6)</h3>
            <p class="thickness" data-i18n="level_6_thickness">40-50mm</p>
            <img src="/img/page2/6.png" alt="RL-6 Protection Level" style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px;">
            <p class="description" data-i18n="level_6_desc">Protection against heavy caliber rounds including .50 BMG. Elite security applications.</p>
            <p class="applications" data-i18n="level_6_applications">Elite Bases, Critical Facilities</p>
        </article>

        <!-- Level 7 -->
        <article class="card product-card" data-level="rl7">
            <h3 data-i18n="level_7_title">Level 7 (RL-7)</h3>
            <p class="thickness" data-i18n="level_7_thickness">80-100mm</p>
            <img src="/img/page2/7.png" alt="RL-7 Protection Level" style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px;">
            <p class="description" data-i18n="level_7_desc">Protection against tank rounds up to 20mm. Military-grade protection for critical infrastructure.</p>
            <p class="applications" data-i18n="level_7_applications">Military Bases, Critical Infrastructure</p>
        </article>

        <!-- Level 8 -->
        <article class="card product-card" data-level="rl8">
            <h3 data-i18n="level_8_title">Level 8 (RL-8)</h3>
            <p class="thickness" data-i18n="level_8_thickness">120+mm</p>
            <img src="/img/page2/8.png" alt="RL-8 Protection Level" style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px;">
            <p class="description" data-i18n="level_8_desc">Maximum protection against artillery shells up to 155mm. Ultimate security for elite bunkers.</p>
            <p class="applications" data-i18n="level_8_applications">Elite Bunkers, Maximum Security</p>
        </article>
    </section>

    <!-- Brand Logo -->
    <section class="brand-logo">
        <img src="/img/page2/logo.png" alt="Crystal Defence" style="max-width: 200px;">
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <h2 data-i18n="products_cta_title">Need Custom Protection?</h2>
        <p data-i18n="products_cta_desc">Contact us for consultation on UL 752 certified glass solutions tailored to your needs.</p>
        <a href="#contact" class="btn" data-i18n="contact_cta">Get a Quote</a>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer__content">
            <p data-i18n="footer_info">Kyiv, Ukraine | &copy; 2026 Crystal Defence</p>
            <span class="contact-info" style="margin-top: 10px;">
                <a href="mailto:info@crystaldefence.com">info@crystaldefence.com</a><br>
                +380000000001
            </span>
        </div>
    </footer>

    <!-- Подключение скриптов -->
    <script src="/js/app.js"></script>
    <script src="/js/animations.js"></script>
</body>
</html>
